#!/usr/bin/env bash
# Scatter wrapper — Ardour multitrack DAW (GPL). Opens Ardour if installed.

set -euo pipefail

SCATTER_CORE="/home/ryannlynnmurphy/scatter-system/scatter_core.py"
PROFILE=$(python3 "$SCATTER_CORE" profile 2>/dev/null || echo researcher)

python3 "$SCATTER_CORE" - <<'PYJOURNAL' 2>/dev/null || true
import scatter_core as sc
sc.journal_append(
    "commons_launch",
    slug="ardour",
    provenance="Ardour — Ardour authors",
    profile=sc.profile(),
)
PYJOURNAL

if command -v firejail >/dev/null 2>&1; then
  exec firejail ardour "$@"
fi

exec ardour "$@"
